{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "rewrites": [{

    "source": "/api/:path*",
    "destination": "https://amana-bckend-api.vercel.app/api/:path*" 
  }]
  
}
