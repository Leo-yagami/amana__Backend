<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Complete Your Donation - CompassionEditorial</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Manrope:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-secondary-fixed": "#341100",
                        "outline": "#6c7a77",
                        "secondary-fixed": "#ffdbca",
                        "surface-container-highest": "#e0e3e5",
                        "error": "#ba1a1a",
                        "inverse-on-surface": "#eff1f3",
                        "surface-container-lowest": "#ffffff",
                        "surface-container": "#eceef0",
                        "surface-bright": "#f7f9fb",
                        "on-background": "#191c1e",
                        "tertiary": "#9b4426",
                        "tertiary-container": "#f38764",
                        "on-primary-fixed-variant": "#005048",
                        "on-error-container": "#93000a",
                        "on-tertiary-fixed-variant": "#7c2d11",
                        "surface-container-high": "#e6e8ea",
                        "tertiary-fixed": "#ffdbd0",
                        "on-primary-fixed": "#00201c",
                        "surface-container-low": "#f2f4f6",
                        "error-container": "#ffdad6",
                        "outline-variant": "#bbcac6",
                        "on-error": "#ffffff",
                        "on-secondary": "#ffffff",
                        "background": "#f7f9fb",
                        "secondary": "#9d4300",
                        "surface-tint": "#006b5f",
                        "surface": "#f7f9fb",
                        "on-surface-variant": "#3c4947",
                        "secondary-container": "#fd761a",
                        "on-tertiary-container": "#6c2106",
                        "primary-fixed": "#71f8e4",
                        "surface-dim": "#d8dadc",
                        "primary": "#006b5f",
                        "on-tertiary": "#ffffff",
                        "on-secondary-container": "#5c2400",
                        "inverse-primary": "#4fdbc8",
                        "primary-fixed-dim": "#4fdbc8",
                        "on-primary": "#ffffff",
                        "surface-variant": "#e0e3e5",
                        "on-primary-container": "#00423b",
                        "on-tertiary-fixed": "#3a0b00",
                        "on-surface": "#191c1e",
                        "tertiary-fixed-dim": "#ffb59e",
                        "primary-container": "#14b8a6",
                        "inverse-surface": "#2d3133",
                        "secondary-fixed-dim": "#ffb690",
                        "on-secondary-fixed-variant": "#783200"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Manrope"],
                        "label": ["Manrope"]
                    }
                }
            }
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .ambient-shadow {
            box-shadow: 0 20px 40px -10px rgba(0, 107, 95, 0.06);
        }
    </style>
</head>
<body class="bg-surface font-body text-on-surface antialiased">
<main class="py-20 px-6 max-w-7xl mx-auto">
<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
<!-- Main Column (Left) -->
<div class="lg:col-span-8 space-y-10">
<header>
<h1 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tight text-on-surface mb-4">Complete Your Donation</h1>
<p class="text-on-surface-variant text-lg leading-relaxed max-w-2xl">Your contribution empowers our mission to drive positive change and support vital causes in communities across the globe. Every donation makes a meaningful difference.</p>
</header>
<!-- Donation Amount Selector -->
<section class="space-y-6">
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary" data-icon="payments">payments</span>
<h2 class="text-xl font-bold font-headline">Select Donation Amount</h2>
</div>
<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
<button class="py-6 px-4 bg-surface-container-lowest border-2 border-transparent hover:border-primary/40 rounded-xl transition-all group flex flex-col items-center gap-1 ambient-shadow">
<span class="text-2xl font-bold font-headline text-on-surface">$10</span>
<span class="text-xs text-on-surface-variant">Simple Gift</span>
</button>
<button class="py-6 px-4 bg-primary-container/10 border-2 border-primary rounded-xl transition-all group flex flex-col items-center gap-1 ambient-shadow relative">
<div class="absolute -top-2 right-4 bg-secondary text-white text-[10px] px-2 py-0.5 rounded-full font-bold uppercase tracking-wider">Most Popular</div>
<span class="text-2xl font-bold font-headline text-primary">$25</span>
<span class="text-xs text-primary-container font-medium">Impactful</span>
</button>
<button class="py-6 px-4 bg-surface-container-lowest border-2 border-transparent hover:border-primary/40 rounded-xl transition-all group flex flex-col items-center gap-1 ambient-shadow">
<span class="text-2xl font-bold font-headline text-on-surface">$50</span>
<span class="text-xs text-on-surface-variant">Generous</span>
</button>
<div class="relative">
<input class="w-full h-full py-6 px-4 bg-surface-container-lowest border-2 border-outline-variant/20 focus:border-primary/40 focus:ring-0 rounded-xl text-center font-bold font-headline text-xl ambient-shadow placeholder:text-on-surface-variant/50" placeholder="Custom" type="text"/>
</div>
</div>
</section>
<!-- Payment Method Section -->
<section class="space-y-6">
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary" data-icon="account_balance_wallet">account_balance_wallet</span>
<h2 class="text-xl font-bold font-headline">Payment Method</h2>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div class="p-5 bg-primary-container/5 border border-primary rounded-xl cursor-pointer flex items-center gap-4 transition-all">
<div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
<span class="material-symbols-outlined text-primary" data-icon="credit_card">credit_card</span>
</div>
<div class="flex flex-col">
<span class="font-bold text-sm">Credit/Debit Card</span>
<span class="text-xs text-on-surface-variant">Secure checkout</span>
</div>
</div>
<div class="p-5 bg-surface-container-lowest border border-outline-variant/10 rounded-xl cursor-pointer flex items-center gap-4 hover:bg-surface-container-low transition-all">
<div class="w-10 h-10 bg-surface-container-highest rounded-lg flex items-center justify-center">
<span class="material-symbols-outlined text-on-surface-variant" data-icon="account_balance">account_balance</span>
</div>
<div class="flex flex-col">
<span class="font-bold text-sm">Telebirr</span>
<span class="text-xs text-on-surface-variant">Mobile payment</span>
</div>
</div>
</div>
</section>
<!-- Card Details Form -->
<section class="bg-surface-container-low p-8 rounded-2xl space-y-6">
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<div class="md:col-span-2 space-y-2">
<label class="text-sm font-semibold text-on-surface-variant ml-1">Card Number</label>
<div class="relative">
<input class="w-full px-5 py-4 bg-surface-container-lowest border border-outline-variant/20 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="0000 0000 0000 0000" type="text"/>
<span class="absolute right-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-on-surface-variant/40" data-icon="lock">lock</span>
</div>
</div>
<div class="space-y-2">
<label class="text-sm font-semibold text-on-surface-variant ml-1">Expiry Date</label>
<input class="w-full px-5 py-4 bg-surface-container-lowest border border-outline-variant/20 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="MM / YY" type="text"/>
</div>
<div class="space-y-2">
<label class="text-sm font-semibold text-on-surface-variant ml-1">CVV Code</label>
<div class="relative">
<input class="w-full px-5 py-4 bg-surface-container-lowest border border-outline-variant/20 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="***" type="password"/>
<span class="absolute right-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-on-surface-variant/40 cursor-help" data-icon="help">help</span>
</div>
</div>
</div>
</section>
</div>
<!-- Sidebar (Right) -->
<aside class="lg:col-span-4 sticky top-10">
<div class="bg-surface-container-lowest rounded-2xl ambient-shadow overflow-hidden border border-outline-variant/10">
<div class="p-8 relative">
<h3 class="text-xl font-bold font-headline mb-6">Donation Summary</h3>
<div class="space-y-4 mb-8">
<div class="flex justify-between items-center text-sm">
<span class="text-on-surface-variant">Donation for Clean Water</span>
<span class="font-semibold">$25.00</span>
</div>
<div class="flex justify-between items-center text-sm">
<span class="text-on-surface-variant">Processing Fee</span>
<span class="font-semibold">$0.75</span>
</div>
<div class="pt-4 mt-4 border-t border-surface-container-high flex justify-between items-end">
<span class="text-sm font-medium">Total Amount</span>
<span class="text-3xl font-extrabold text-primary font-headline tracking-tight">$25.75</span>
</div>
</div>
<!-- Progress visual -->
<button class="w-full py-5 bg-gradient-to-br from-secondary to-secondary-container text-white rounded-full font-bold text-lg shadow-lg hover:shadow-secondary/20 hover:scale-[1.01] transition-all flex items-center justify-center gap-3">
<a href="/initialize">Complete Donation</a>
<span class="material-symbols-outlined text-xl" data-icon="volunteer_activism" data-weight="fill">volunteer_activism</span>
</button>
<p class="mt-6 text-[11px] text-center text-on-surface-variant leading-relaxed px-4">
                        By clicking "Complete Donation", you agree to our Terms of Service and Privacy Policy. All transactions are secure and encrypted.
                    </p>
</div>
</div>
<!-- Trust Badge -->
<div class="mt-6 p-4 border border-outline-variant/10 rounded-xl flex items-center gap-4 bg-surface-container-low/50">
<span class="material-symbols-outlined text-primary text-3xl" data-icon="verified_user">verified_user</span>
<div>
<p class="text-xs font-bold uppercase tracking-wider text-on-surface">Secure Transaction</p>
<p class="text-[10px] text-on-surface-variant">256-bit SSL encryption protects your data.</p>
</div>
</div>
</aside>
</div>
</main>
</body></html>